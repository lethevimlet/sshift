#!/usr/bin/env node

/**
 * sshift - Web-based SSH & SFTP Terminal Client
 * 
 * This is the main entry point for the sshift application.
 * Run this file to start the server.
 * 
 * Usage:
 *   ./sshift                      # Start server on default port (8022)
 *   ./sshift --port 8080          # Start server on custom port
 *   ./sshift --bind 127.0.0.1     # Bind to specific address
 *   ./sshift --dev                # Start in development mode (port 3000)
 *   ./sshift --stop               # Stop running instance
 *   ./sshift --restart            # Restart running instance
 *   ./sshift --status             # Check if sshift is running
 *   ./sshift --help               # Show help message
 * 
 * Environment Variables:
 *   PORT=8080 ./sshift             # Start server on custom port (overrides config)
 *   BIND=127.0.0.1 ./sshift       # Bind to specific address (overrides config)
 *   NODE_ENV=development ./sshift  # Start in dev mode (port 3000, or from config)
 * 
 * Port Priority:
 *   1. --port CLI argument (highest priority)
 *   2. PORT environment variable
 *   3. config.json port/devPort based on NODE_ENV
 *   4. Default: 8022 (production), 3000 (development)
 */

'use strict';

const path = require('path');
const fs = require('fs');
const os = require('os');

// Get the directory where this script is located
const scriptDir = __dirname;
const serverPath = path.join(scriptDir, 'src', 'server', 'index.js');

// CLI argument parsing
const args = process.argv.slice(2);
const options = {
  port: null,
  bind: null,
  dev: false,
  stop: false,
  restart: false,
  status: false,
  help: false
};

// Parse arguments
for (let i = 0; i < args.length; i++) {
  const arg = args[i];
  if (arg === '--port' || arg === '-p') {
    options.port = parseInt(args[++i], 10);
    if (isNaN(options.port)) {
      console.error('Error: --port requires a valid port number');
      process.exit(1);
    }
  } else if (arg === '--bind' || arg === '-b') {
    options.bind = args[++i];
    if (!options.bind) {
      console.error('Error: --bind requires an address');
      process.exit(1);
    }
  } else if (arg === '--dev' || arg === '-d') {
    options.dev = true;
  } else if (arg === '--stop' || arg === '-s') {
    options.stop = true;
  } else if (arg === '--restart' || arg === '-r') {
    options.restart = true;
  } else if (arg === '--status') {
    options.status = true;
  } else if (arg === '--help' || arg === '-h') {
    options.help = true;
  } else {
    console.error(`Error: Unknown argument: ${arg}`);
    console.error('Use --help for usage information');
    process.exit(1);
  }
}

// PID file: dev instance uses a separate file so both can run side by side
const pidFile = path.join(os.homedir(), '.local', 'share', 'sshift', options.dev ? '.sshift-dev.pid' : '.sshift.pid');

// Show help
if (options.help) {
  console.log(`
sshift - Web-based SSH & SFTP Terminal Client

Usage:
  ./sshift                      Start server on default port (8022)
  ./sshift --port 8080          Start server on custom port
  ./sshift --bind 127.0.0.1     Bind to specific address
  ./sshift --dev                Start in development mode (port 3000)
  ./sshift --stop               Stop running instance
  ./sshift --restart            Restart running instance
  ./sshift --status             Check if sshift is running
  ./sshift --dev --status       Check if dev instance is running
  ./sshift --dev --stop         Stop dev instance
  ./sshift --dev --restart      Restart dev instance
  ./sshift --help               Show this help message

Options:
  -p, --port <port>     Server port (default: 8022, dev: 3000)
  -b, --bind <address> Bind address (default: 0.0.0.0)
  -d, --dev             Development mode (separate PID file for --status/--stop/--restart)
  -s, --stop            Stop running instance
  -r, --restart         Restart running instance
  --status              Check running status
  -h, --help            Show this help message

Environment Variables:
  PORT=8080             Override port
  BIND=127.0.0.1        Override bind address
  NODE_ENV=development  Development mode

Examples:
  ./sshift                          # Start on default port
  ./sshift --port 9000              # Start on port 9000
  ./sshift --dev                    # Start in dev mode
  ./sshift --bind 127.0.0.1         # Bind to localhost only
  ./sshift --stop                   # Stop running instance
  ./sshift --restart                # Restart running instance
  PORT=8080 ./sshift                # Start on port 8080 (env var)
`);
  process.exit(0);
}

// Check if index.js exists
if (!fs.existsSync(serverPath)) {
  console.error('Error: index.js not found');
  console.error('Make sure you are running sshift from the installation directory');
  process.exit(1);
}

// Helper: Ensure PID file directory exists
function ensurePidDir() {
  const dir = path.dirname(pidFile);
  if (!fs.existsSync(dir)) {
    fs.mkdirSync(dir, { recursive: true });
  }
}

// Helper: Write current PID to file
function writePidFile() {
  ensurePidDir();
  fs.writeFileSync(pidFile, process.pid.toString(), { mode: 0o644 });
}

// Helper: Remove PID file
function cleanupPidFile() {
  try {
    if (fs.existsSync(pidFile)) {
      const storedPid = parseInt(fs.readFileSync(pidFile, 'utf8').trim(), 10);
      if (isNaN(storedPid) || storedPid === process.pid) {
        fs.unlinkSync(pidFile);
      }
    }
  } catch (e) {
    // Ignore cleanup errors
  }
}

// Helper: Check if sshift is running
function isRunning() {
  if (fs.existsSync(pidFile)) {
    try {
      const pid = parseInt(fs.readFileSync(pidFile, 'utf8').trim(), 10);
      if (isNaN(pid)) return { running: false };
      
      // Check if process exists
      try {
        process.kill(pid, 0);
        return { running: true, pid };
      } catch (e) {
        // Process not running, clean up stale PID file
        fs.unlinkSync(pidFile);
        return { running: false };
      }
    } catch (e) {
      return { running: false };
    }
  }
  return { running: false };
}

// Helper: Stop running instance
function stopInstance(label) {
  const status = isRunning();
  
  if (!status.running) {
    console.log(`${label} is not running`);
    return true;
  }
  
  console.log(`Stopping ${label} (PID: ${status.pid})...`);
  
  try {
    process.kill(status.pid, 'SIGTERM');
    
    // Wait for process to stop (up to 10 seconds)
    let attempts = 0;
    while (attempts < 10) {
      try {
        process.kill(status.pid, 0);
        // Still running, wait
        Atomics.wait(new Int32Array(new SharedArrayBuffer(4)), 0, 0, 1000);
        attempts++;
      } catch (e) {
        // Process stopped
        break;
      }
    }
    
    // Force kill if still running
    try {
      process.kill(status.pid, 0);
      console.log('Process did not stop gracefully, force killing...');
      process.kill(status.pid, 'SIGKILL');
      Atomics.wait(new Int32Array(new SharedArrayBuffer(4)), 0, 0, 1000);
    } catch (e) {
      // Already stopped
    }
    
    // Clean up PID file
    if (fs.existsSync(pidFile)) {
      fs.unlinkSync(pidFile);
    }
    
    console.log(`${label} stopped successfully`);
    return true;
  } catch (e) {
    console.error(`Error stopping ${label}: ${e.message}`);
    return false;
  }
}

// Handle --status
if (options.status) {
  const status = isRunning();
  const label = options.dev ? 'sshift (dev)' : 'sshift';
  if (status.running) {
    console.log(`${label} is running (PID: ${status.pid})`);
    process.exit(0);
  } else {
    console.log(`${label} is not running`);
    process.exit(1);
  }
}

// Handle --stop
if (options.stop) {
  const label = options.dev ? 'sshift (dev)' : 'sshift';
  const success = stopInstance(label);
  process.exit(success ? 0 : 1);
}

// Handle --restart
if (options.restart) {
  const label = options.dev ? 'sshift (dev)' : 'sshift';
  console.log(`Restarting ${label}...`);
  stopInstance(label);
  // Continue to start below
}

// For start operations, change to script directory
process.chdir(scriptDir);

// Load environment variables from .env files
// Priority: .env/.env.local > .env.local > .env/.env > .env
const envPaths = [
  path.join(scriptDir, '.env', '.env.local'),
  path.join(scriptDir, '.env.local'),
  path.join(scriptDir, '.env', '.env'),
  path.join(scriptDir, '.env')
];

// Load dotenv if available
try {
  const dotenv = require('dotenv');
  envPaths.forEach(envPath => {
    if (fs.existsSync(envPath)) {
      dotenv.config({ path: envPath });
    }
  });
} catch (e) {
  // dotenv not available, environment variables will be loaded by server.js
}

// Set environment variables from CLI options
if (options.port !== null) {
  process.env.PORT = options.port.toString();
}
if (options.bind) {
  process.env.BIND = options.bind;
}
if (options.dev) {
  process.env.NODE_ENV = 'development';
}

// Write PID file before starting
writePidFile();

// Clean up PID file on exit
process.on('exit', cleanupPidFile);
process.on('SIGTERM', () => {
  cleanupPidFile();
  process.exit(0);
});
process.on('SIGINT', () => {
  cleanupPidFile();
  process.exit(0);
});

// Start the server
require(serverPath);