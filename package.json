{
  "name": "@lethevimlet/sshift",
  "version": "1.5.0",
  "description": "Web-based SSH + SFTP terminal client with tabs and bookmarks",
  "main": "src/server/index.js",
  "bin": {
    "sshift": "./sshift"
  },
  "scripts": {
    "start": "node sshift",
    "dev": "NODE_ENV=development node sshift",
    "test": "jest --forceExit --runInBand",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --forceExit --runInBand",
    "test:unit": "jest --testPathPatterns='src/tests/unit' --forceExit",
    "test:integration": "jest --testPathPatterns='src/tests/integration' --forceExit",
    "test:e2e": "jest --testPathPatterns='src/tests/e2e' --forceExit --runInBand",
    "test:browser": "jest --testPathPatterns='src/tests/browser' --forceExit --runInBand",
    "test:ssh:up": "docker compose -f docker/test-ssh/docker-compose.yml up -d --build",
    "test:ssh:down": "docker compose -f docker/test-ssh/docker-compose.yml down -v",
    "test:ssh:logs": "docker compose -f docker/test-ssh/docker-compose.yml logs -f",
    "prepublishOnly": "echo 'Publishing to npm...'",
    "install:safe": "sfw pnpm install"
  },
  "dependencies": {
    "@xterm/addon-fit": "0.11.0",
    "@xterm/addon-image": "0.9.0",
    "@xterm/addon-search": "0.16.0",
    "@xterm/addon-serialize": "0.14.0",
    "@xterm/addon-unicode11": "0.9.0",
    "@xterm/addon-web-links": "0.12.0",
    "@xterm/addon-webgl": "0.19.0",
    "@xterm/headless": "6.0.0",
    "@xterm/xterm": "6.0.0",
    "dotenv": "17.4.0",
    "express": "4.18.2",
    "httpolyglot": "0.1.2",
    "lucide": "1.7.0",
    "selfsigned": "5.5.0",
    "socket.io": "4.7.2",
    "ssh2": "1.15.0",
    "uuid": "9.0.0"
  },
  "keywords": [
    "ssh",
    "sftp",
    "terminal",
    "web",
    "xterm",
    "web-terminal",
    "ssh-client",
    "sftp-client",
    "browser-terminal"
  ],
  "author": "lethevimlet",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lethevimlet/sshift.git"
  },
  "bugs": {
    "url": "https://github.com/lethevimlet/sshift/issues"
  },
  "homepage": "https://github.com/lethevimlet/sshift#readme",
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@10.33.4",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "files": [
    "sshift",
    "sshift-install.sh",
    "sshift-install.ps1",
    "src/server/",
    "src/webapp/",
    "plugins/",
    "example.config.json",
    "README.md",
    "LICENSE"
  ],
  "devDependencies": {
    "@types/jest": "30.0.0",
    "jest": "30.3.0",
    "puppeteer": "24.40.0",
    "socket.io-client": "4.8.3",
    "ts-jest": "29.4.9"
  }
}
