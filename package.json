{
  "name": "sshift",
  "version": "0.0.1",
  "description": "Web-based SSH + SFTP terminal client with tabs and bookmarks",
  "main": "server.js",
  "bin": {
    "sshift": "./sshift"
  },
  "scripts": {
    "start": "node sshift",
    "dev": "NODE_ENV=development node sshift",
    "test": "node test/test-client.js",
    "test:server": "node server.js & sleep 2 && node test/test-client.js"
  },
  "dependencies": {
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/headless": "^6.0.0",
    "dotenv": "^17.4.0",
    "express": "^4.18.2",
    "socket.io": "^4.7.2",
    "ssh2": "^1.15.0",
    "uuid": "^9.0.0"
  },
  "keywords": [
    "ssh",
    "sftp",
    "terminal",
    "web",
    "xterm"
  ],
  "license": "MIT",
  "devDependencies": {
    "puppeteer": "^24.40.0",
    "socket.io-client": "^4.8.3"
  }
}
