{
  "name": "@lethevimlet/sshift",
  "version": "0.1.9",
  "description": "Web-based SSH + SFTP terminal client with tabs and bookmarks",
  "main": "src/server/index.js",
  "bin": {
    "sshift": "./sshift"
  },
  "scripts": {
    "start": "node sshift",
    "dev": "NODE_ENV=development node sshift",
    "test": "jest --forceExit --runInBand",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --forceExit --runInBand",
    "test:unit": "jest --testPathPatterns='src/tests/unit' --forceExit",
    "test:integration": "jest --testPathPatterns='src/tests/integration' --forceExit",
    "test:e2e": "jest --testPathPatterns='src/tests/e2e' --forceExit --runInBand",
    "test:browser": "jest --testPathPatterns='src/tests/browser' --forceExit --runInBand",
    "prepublishOnly": "echo 'Publishing to npm...'"
  },
  "dependencies": {
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/headless": "^6.0.0",
    "dotenv": "^17.4.0",
    "express": "^4.18.2",
    "lucide": "^1.7.0",
    "socket.io": "^4.7.2",
    "ssh2": "^1.15.0",
    "uuid": "^9.0.0"
  },
  "keywords": [
    "ssh",
    "sftp",
    "terminal",
    "web",
    "xterm",
    "web-terminal",
    "ssh-client",
    "sftp-client",
    "browser-terminal"
  ],
  "author": "lethevimlet",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lethevimlet/sshift.git"
  },
  "bugs": {
    "url": "https://github.com/lethevimlet/sshift/issues"
  },
  "homepage": "https://github.com/lethevimlet/sshift#readme",
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "files": [
    "sshift",
    "src/server/",
    "src/webapp/",
    "example.config.json",
    "README.md",
    "LICENSE"
  ],
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "jest": "^30.3.0",
    "puppeteer": "^24.40.0",
    "socket.io-client": "^4.8.3",
    "ts-jest": "^29.4.9"
  }
}
